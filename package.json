{
  "name": "coolify-code-mode-mcp",
  "version": "0.1.0",
  "description": "Code Mode MCP server for the Coolify API.",
  "type": "module",
  "bin": {
    "coolify-mcp": "./dist/coolify-mcp",
    "coolify-code-mode-mcp": "./dist/coolify-mcp"
  },
  "files": [
    "dist",
    "openapi",
    "docs",
    "skills",
    "scripts",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "rm -rf dist && bun build ./src/index.ts --compile --outfile=dist/coolify-mcp",
    "clean": "rm -rf dist",
    "dev": "bun src/index.ts",
    "generate": "bun scripts/update-openapi.ts",
    "prepack": "bun run build",
    "start": "./dist/coolify-mcp",
    "test": "bun test tests/*.test.mjs",
    "typecheck": "tsc --noEmit",
    "verify": "bun run generate && bun run typecheck && bun test tests/*.test.mjs && bun run build"
  },
  "keywords": [
    "coolify",
    "mcp",
    "model-context-protocol",
    "codemode",
    "openapi"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.18.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.0.10",
    "typescript": "^5.8.3"
  },
  "engines": {
    "bun": ">=1.3.8"
  }
}
